# Database (MySQL connection string)
# Encode special chars: @ → %40, % → %25
DATABASE_URL="mysql://user:password@host:3306/database"

# NextAuth session encryption (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=""

# Site URL (used in sitemap, RSS, robots, metadata)
SITE_URL="https://jobreadyke.co.ke"
