// ─── JobReady Database Schema ───
// Provider: mysql (production via Vercel)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Companies / Employers ───

model Company {
  id          String    @id @default(cuid()) @db.VarChar(64)
  slug        String    @unique @db.VarChar(191)
  name        String    @db.VarChar(191)
  logo        String?   @db.VarChar(500)
  verified    Boolean   @default(false)
  orgType     String    @default("PRIVATE") @db.VarChar(30)
  industry    String?   @db.VarChar(100)
  description String?   @db.Text
  website     String?   @db.VarChar(500)
  location    String?   @db.VarChar(191)
  county      String?   @db.VarChar(100)
  country     String    @default("Kenya") @db.VarChar(100)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  listings Listing[]
}

// ─── Job Categories ───

model Category {
  id        String        @id @default(cuid()) @db.VarChar(64)
  slug      String        @unique @db.VarChar(191)
  name      String        @db.VarChar(191)
  icon      String?       @db.VarChar(50)
  sortOrder Int           @default(0)
  active    Boolean       @default(true)

  subcategories Subcategory[]
  listings      Listing[]
}

// ─── Subcategories ───

model Subcategory {
  id         String   @id @default(cuid()) @db.VarChar(64)
  slug       String   @unique @db.VarChar(191)
  name       String   @db.VarChar(191)
  categoryId String   @db.VarChar(64)
  sortOrder  Int      @default(0)
  active     Boolean  @default(true)

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  listings Listing[]
}

// ─── Counties ───

model County {
  id        String   @id @default(cuid()) @db.VarChar(64)
  slug      String   @unique @db.VarChar(191)
  name      String   @db.VarChar(100)
  code      String?  @db.VarChar(10)
  active    Boolean  @default(true)

  listings Listing[]
}

// ─── Tags ───

model Tag {
  id   String @id @default(cuid()) @db.VarChar(64)
  name String @unique @db.VarChar(100)

  listings ListingTag[]
}

// ─── Listings (Jobs / Government / Casual / Opportunities) ───

model Listing {
  id              String       @id @default(cuid()) @db.VarChar(64)
  slug            String       @unique @db.VarChar(191)
  title           String       @db.VarChar(300)
  description     String       @default("") @db.Text
  requirements    String?      @db.Text
  instructions    String?      @db.Text

  // Type
  listingType     String       @default("JOB") @db.VarChar(20)
  governmentLevel String?      @db.VarChar(30)
  opportunityType String?      @db.VarChar(30)

  // Employer
  companyId       String       @db.VarChar(64)
  company         Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Classification
  categoryId      String?      @db.VarChar(64)
  category        Category?    @relation(fields: [categoryId], references: [id])
  subcategoryId   String?      @db.VarChar(64)
  subcategory     Subcategory? @relation(fields: [subcategoryId], references: [id])

  // Location
  location        String       @default("") @db.VarChar(191)
  countyId        String?      @db.VarChar(64)
  county          County?      @relation(fields: [countyId], references: [id])
  countyName      String       @default("") @db.VarChar(100)
  country         String       @default("Kenya") @db.VarChar(100)

  // Employment details
  employmentType  String       @default("Full-time") @db.VarChar(20)
  experienceLevel String       @default("Mid-level") @db.VarChar(20)
  workMode        String       @default("ONSITE") @db.VarChar(20)

  // Salary
  salaryMin       Int?
  salaryMax       Int?
  salaryCurrency  String       @default("KES") @db.VarChar(10)
  salaryPeriod    String?      @db.VarChar(10)

  // AI-predicted salary (shown when salary not disclosed)
  predictedSalary  String?     @db.VarChar(100)
  isPredictedSalary Boolean @default(false)

  // Status & visibility
  status          String       @default("ACTIVE") @db.VarChar(20)
  featured        Boolean      @default(false)
  isUrgent        Boolean      @default(false)

  // Application
  applicationUrl  String?      @db.VarChar(500)
  applyEmail      String?      @db.VarChar(191)
  applyCount      Int          @default(0)

  // Metadata
  source          String?      @db.VarChar(191)
  viewCount       Int          @default(0)

  // Dates
  deadline        DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  tags ListingTag[]

  @@index([listingType])
  @@index([categoryId])
  @@index([countyId])
  @@index([countyName])
  @@index([companyId])
  @@index([status])
  @@index([featured])
  @@index([deadline])
  @@index([createdAt])
  @@index([governmentLevel])
  @@index([opportunityType])
  @@index([employmentType])
  @@index([experienceLevel])
  @@index([workMode])
  @@index([listingType, status])
  @@index([listingType, countyName])
}

// ─── Job Updates (official announcements from ministries, employers) ───

model JobUpdate {
  id          String   @id @default(cuid()) @db.VarChar(64)
  slug        String   @unique @db.VarChar(191)
  title       String   @db.VarChar(500)
  body        String?  @db.Text
  source      String   @db.VarChar(191)
  updateType  String   @default("ANNOUNCEMENT") @db.VarChar(30)
  pdfUrl      String?  @db.VarChar(500)
  imageUrl    String?  @db.VarChar(500)
  listingSlug String?  @db.VarChar(191)
  postedBy    String   @default("admin") @db.VarChar(191)
  status      String   @default("PUBLISHED") @db.VarChar(20)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([updateType])
  @@index([status])
  @@index([createdAt])
  @@index([slug])
}

// ─── Listing ↔ Tag junction ───

model ListingTag {
  listingId String @db.VarChar(64)
  tagId     String @db.VarChar(64)

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([listingId, tagId])
}
