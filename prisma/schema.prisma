// ─── JobReady Database Schema ───
// Provider: mysql (production via Vercel)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Companies / Employers ───

model Company {
  id          String    @id @default(cuid()) @db.VarChar(64)
  slug        String    @unique @db.VarChar(191)
  name        String    @db.VarChar(191)
  logo        String?   @db.VarChar(500)
  verified    Boolean   @default(false)
  orgType     String    @default("PRIVATE") @db.VarChar(30)
  industry    String?   @db.VarChar(100)
  description String?   @db.Text
  website     String?   @db.VarChar(500)
  location    String?   @db.VarChar(191)
  county      String?   @db.VarChar(100)
  country     String    @default("Kenya") @db.VarChar(100)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  listings Listing[]
  socialAccounts SocialAccount[]
  users     User[]
}

// ─── Job Categories ───

model Category {
  id        String        @id @default(cuid()) @db.VarChar(64)
  slug      String        @unique @db.VarChar(191)
  name      String        @db.VarChar(191)
  icon      String?       @db.VarChar(50)
  sortOrder Int           @default(0)
  active    Boolean       @default(true)

  subcategories Subcategory[]
  listings      Listing[]
}

// ─── Subcategories ───

model Subcategory {
  id         String   @id @default(cuid()) @db.VarChar(64)
  slug       String   @unique @db.VarChar(191)
  name       String   @db.VarChar(191)
  categoryId String   @db.VarChar(64)
  sortOrder  Int      @default(0)
  active     Boolean  @default(true)

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  listings Listing[]
}

// ─── Counties ───

model County {
  id        String   @id @default(cuid()) @db.VarChar(64)
  slug      String   @unique @db.VarChar(191)
  name      String   @db.VarChar(100)
  code      String?  @db.VarChar(10)
  active    Boolean  @default(true)

}

// ─── Tags ───

model Tag {
  id   String @id @default(cuid()) @db.VarChar(64)
  name String @unique @db.VarChar(100)

  listings ListingTag[]
}

// ─── Listings (Jobs / Government / Casual / Opportunities) ───

model Listing {
  id              String       @id @default(cuid()) @db.VarChar(64)
  slug            String       @unique @db.VarChar(191)
  title           String       @db.VarChar(300)
  description     String       @default("") @db.Text

  // Type
  listingType     String       @default("JOB") @db.VarChar(20)
  governmentLevel String?      @db.VarChar(30)
  opportunityType String?      @db.VarChar(30)

  // Employer
  companyId       String       @db.VarChar(64)
  company         Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Classification
  categoryId      String?      @db.VarChar(64)
  category        Category?    @relation(fields: [categoryId], references: [id])
  subcategoryId   String?      @db.VarChar(64)
  subcategory     Subcategory? @relation(fields: [subcategoryId], references: [id])

  // Location
  town            String       @default("") @db.VarChar(191)
  county          String       @default("") @db.VarChar(100)

  // Employment details
  employmentType  String       @default("Full-time") @db.VarChar(20)
  experienceLevel String       @default("Mid-level") @db.VarChar(20)
  workMode        String       @default("ONSITE") @db.VarChar(20)

  // Salary
  salaryMin       Int?
  salaryMax       Int?
  salaryPeriod    String?      @db.VarChar(10)

  // AI-predicted salary (shown when salary not disclosed)
  predictedSalary  String?     @db.VarChar(100)

  // Status & visibility
  status          String       @default("ACTIVE") @db.VarChar(20)
  featured        Boolean      @default(false)

  // Application
  applicationUrl  String?      @db.VarChar(500)
  applyEmail      String?      @db.VarChar(191)
  applyCount      Int          @default(0)

  // Metadata
  source          String?      @db.VarChar(191)
  viewCount       Int          @default(0)

  // Dates
  deadline        DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  tags             ListingTag[]
  savedJobs        SavedJob[]
  applications     Application[]
  cvMatchScores    CvMatchScore[]
  listingTests     ListingTest[]
  skillTestResults SkillTestResult[]
  socialPosts      SocialPost[]

  @@index([listingType])
  @@index([categoryId])
  @@index([county])
  @@index([companyId])
  @@index([status])
  @@index([featured])
  @@index([deadline])
  @@index([createdAt])
  @@index([governmentLevel])
  @@index([opportunityType])
  @@index([employmentType])
  @@index([experienceLevel])
  @@index([workMode])
  @@index([listingType, status])
  @@index([listingType, county])
}

// ─── Job Updates (official announcements from ministries, employers) ───

model JobUpdate {
  id          String   @id @default(cuid()) @db.VarChar(64)
  slug        String   @unique @db.VarChar(191)
  title       String   @db.VarChar(500)
  body        String?  @db.Text
  source      String   @db.VarChar(191)
  updateType  String   @default("ANNOUNCEMENT") @db.VarChar(30)
  pdfUrl      String?  @db.VarChar(500)
  imageUrl    String?  @db.VarChar(500)
  listingSlug String?  @db.VarChar(191)
  postedBy    String   @default("admin") @db.VarChar(191)
  status      String   @default("PUBLISHED") @db.VarChar(20)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([updateType])
  @@index([status])
  @@index([createdAt])
  @@index([slug])
}

// ─── Articles (Career blog posts, guides, resources) ───

model Article {
  id          String   @id @default(cuid()) @db.VarChar(64)
  slug        String   @unique @db.VarChar(191)
  title       String   @db.VarChar(500)
  excerpt     String   @db.Text
  body        String   @db.LongText
  coverImage  String?  @db.VarChar(500)
  category    String   @default("Career Tips") @db.VarChar(100)
  tags        String?  @db.VarChar(500)
  author      String   @default("JobReady Team") @db.VarChar(191)
  authorImage String?  @db.VarChar(500)
  status      String   @default("PUBLISHED") @db.VarChar(20)
  featured    Boolean  @default(false)
  readTime    Int      @default(5)
  viewCount   Int      @default(0)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([status])
  @@index([publishedAt])
  @@index([slug])
  @@index([featured])
}

// ─── Listing ↔ Tag junction ───

model ListingTag {
  listingId String @db.VarChar(64)
  tagId     String @db.VarChar(64)

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([listingId, tagId])
}

// ─── Users ───

model User {
  id            String    @id @default(cuid()) @db.VarChar(64)
  email         String    @unique @db.VarChar(191)
  passwordHash  String    @db.VarChar(255)
  name          String    @default("") @db.VarChar(191)
  phone         String?   @db.VarChar(20)
  county        String?   @db.VarChar(100)
  bio           String?   @db.Text
  cvUrl         String?   @db.VarChar(500)
  avatarUrl     String?   @db.VarChar(500)
  role          String    @default("SEEKER") @db.VarChar(20) // SEEKER, EMPLOYER, ADMIN
  companyId     String?   @db.VarChar(64) // set for EMPLOYER role
  resetToken     String?   @db.VarChar(255)
  resetTokenExpiry DateTime?
  emailVerified Boolean   @default(false)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  savedJobs          SavedJob[]
  applications       Application[]
  jobAlerts          JobAlert[]
  subscriptions      SeekerSubscription[]
  smsLogs            SmsLog[]
  emailLogs          EmailLog[]
  cvMatchScores      CvMatchScore[]
  skillTestResults   SkillTestResult[]
  salarySubmissions  SalarySubmission[]
  socialAccounts      SocialAccount[]
  cvData             CVData?
  company            Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([role])
}

// ─── CV Data (parsed CV storage) ───

model CVData {
  id              String   @id @default(cuid()) @db.VarChar(64)
  userId          String   @unique @db.VarChar(64)
  rawText         String   @db.LongText
  phone           String?  @db.VarChar(30)
  email           String?  @db.VarChar(191)
  location        String?  @db.VarChar(300)
  linkedin        String?  @db.VarChar(500)
  portfolio       String?  @db.VarChar(500)
  summary         String?  @db.Text
  skills          String?  @db.Text // JSON
  strengths       String?  @db.Text // JSON
  experience      String?  @db.Text // JSON
  projects        String?  @db.Text // JSON
  education       String?  @db.Text // JSON
  certifications  String?  @db.Text // JSON
  awards          String?  @db.Text // JSON
  research        String?  @db.Text // JSON
  volunteering    String?  @db.Text // JSON
  languages       String?  @db.Text // JSON
  interests       String?  @db.Text // JSON
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Newsletter Subscription ───

model NewsletterSubscription {
  id              String    @id @default(cuid()) @db.VarChar(64)
  email           String    @unique @db.VarChar(191)
  source          String?   @db.VarChar(100)
  isActive        Boolean   @default(true)
  subscribedAt    DateTime  @default(now())
  unsubscribedAt  DateTime?

  @@index([isActive])
  @@index([subscribedAt])
}

// ─── Saved Jobs ───

model SavedJob {
  id        String   @id @default(cuid()) @db.VarChar(64)
  userId    String   @db.VarChar(64)
  listingId String   @db.VarChar(64)
  note      String?  @db.Text
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
}

// ─── Applications ───

model Application {
  id          String   @id @default(cuid()) @db.VarChar(64)
  userId      String   @db.VarChar(64)
  listingId   String   @db.VarChar(64)
  status      String   @default("DRAFT") @db.VarChar(20)
  coverLetter String?  @db.Text
  cvUrl       String?  @db.VarChar(500)
  appliedAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
  @@index([status])
}

// ─── Job Alerts ───

model JobAlert {
  id            String    @id @default(cuid()) @db.VarChar(64)
  userId        String    @db.VarChar(64)
  name          String    @db.VarChar(191)
  query         String    @db.Text
  frequency     String    @default("DAILY") @db.VarChar(20)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  lastTriggered DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Premium Features ───

// ─── Seeker Subscriptions (candidate premium plans) ───

model SeekerSubscription {
  id                String   @id @default(cuid()) @db.VarChar(64)
  userId            String   @unique @db.VarChar(64)
  plan              String   @default("FREE") @db.VarChar(20) // FREE, PREMIUM_SMS, PREMIUM_ALL
  status            String   @default("ACTIVE") @db.VarChar(20) // ACTIVE, CANCELLED, EXPIRED
  mpesaRef          String?  @db.VarChar(191)
  amount            Int      @default(0)
  currency          String   @default("KES") @db.VarChar(10)
  paymentMethod     String?  @db.VarChar(30)
  currentPeriodStart DateTime @default(now())
  currentPeriodEnd   DateTime
  features          String   @db.Text // JSON array of enabled features
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── SMS Log (track all SMS sent) ───

model SmsLog {
  id          String   @id @default(cuid()) @db.VarChar(64)
  userId      String?  @db.VarChar(64)
  phone       String   @db.VarChar(20)
  message     String   @db.Text
  senderId    String   @default("TALK-SASA") @db.VarChar(50)
  status      String   @default("PENDING") @db.VarChar(20) // PENDING, SENT, FAILED, DELIVERED
  providerRef String?  @db.VarChar(191)
  cost        Float?   @db.Double
  type        String   @default("JOB_ALERT") @db.VarChar(30) // JOB_ALERT, VERIFICATION, MARKETING
  metadata    String?  @db.Text // JSON
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([phone])
  @@index([status])
  @@index([createdAt])
}

// ─── Email Log (track all emails sent) ───

model EmailLog {
  id          String   @id @default(cuid()) @db.VarChar(64)
  userId      String?  @db.VarChar(64)
  to          String   @db.VarChar(191)
  subject     String   @db.VarChar(500)
  status      String   @default("PENDING") @db.VarChar(20) // PENDING, SENT, FAILED, BOUNCED
  template    String?  @db.VarChar(100)
  metadata    String?  @db.Text // JSON
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([to])
  @@index([status])
}

// ─── CV Match Score (AI CV matching results) ───

model CvMatchScore {
  id            String   @id @default(cuid()) @db.VarChar(64)
  userId        String   @db.VarChar(64)
  listingId     String   @db.VarChar(64)
  applicationId String?  @db.VarChar(64)
  score         Int // 0-100
  breakdown     String   @db.Text // JSON with skills, experience, education scores
  aiAnalysis    String?  @db.Text // Full AI analysis text
  modelUsed     String   @default("glm-4") @db.VarChar(50)
  createdAt     DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([listingId])
  @@index([score])
}

// ─── Skill Tests (skills assessment tests) ───

model SkillTest {
  id                String   @id @default(cuid()) @db.VarChar(64)
  title             String   @db.VarChar(300)
  description       String?  @db.Text
  category          String   @default("GENERAL") @db.VarChar(50) // CODING, APTITUDE, ENGLISH, MATH, TECHNICAL, GENERAL
  durationMinutes   Int      @default(15)
  passingScore      Int      @default(60) // percentage
  questionCount     Int      @default(10)
  isActive          Boolean  @default(true)
  pricePerCandidate Int      @default(50) // KES per test
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  questions SkillTestQuestion[]
  listings  ListingTest[]
  results   SkillTestResult[]
}

// ─── Skill Test Questions (questions for tests) ───

model SkillTestQuestion {
  id            String   @id @default(cuid()) @db.VarChar(64)
  testId        String   @db.VarChar(64)
  question      String   @db.Text
  questionType  String   @default("MULTIPLE_CHOICE") @db.VarChar(30) // MULTIPLE_CHOICE, TRUE_FALSE, SHORT_ANSWER
  options       String   @db.Text // JSON array of options
  correctAnswer String   @db.VarChar(500)
  explanation   String?  @db.Text
  sortOrder     Int      @default(0)
  points        Int      @default(1)
  createdAt     DateTime @default(now())

  test SkillTest @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@index([testId])
}

// ─── Listing Tests (attach test to listing) ───

model ListingTest {
  id          String   @id @default(cuid()) @db.VarChar(64)
  listingId   String   @db.VarChar(64)
  testId      String   @db.VarChar(64)
  isRequired  Boolean  @default(true)
  minScore    Int      @default(60) // minimum pass percentage
  createdAt   DateTime @default(now())

  listing Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  test    SkillTest @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@unique([listingId, testId])
  @@index([listingId])
  @@index([testId])
}

// ─── Skill Test Results (candidate test results) ───

model SkillTestResult {
  id               String    @id @default(cuid()) @db.VarChar(64)
  testId           String    @db.VarChar(64)
  userId           String    @db.VarChar(64)
  listingId        String?   @db.VarChar(64)
  applicationId    String?   @db.VarChar(64)
  score            Int // percentage 0-100
  totalPoints      Int       @default(0)
  maxPoints        Int       @default(0)
  answers          String    @db.Text // JSON array of {questionId, answer, isCorrect}
  timeTakenSeconds Int       @default(0)
  status           String    @default("COMPLETED") @db.VarChar(20) // IN_PROGRESS, COMPLETED, TIMED_OUT
  passed           Boolean   @default(false)
  createdAt        DateTime  @default(now())
  completedAt      DateTime?

  test    SkillTest @relation(fields: [testId], references: [id], onDelete: Cascade)
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing?  @relation(fields: [listingId], references: [id], onDelete: SetNull)

  @@index([testId])
  @@index([userId])
  @@index([listingId])
  @@index([applicationId])
  @@unique([userId, testId, listingId])
}

// ─── Social Accounts (connected social media accounts) ───

model SocialAccount {
  id                String   @id @default(cuid()) @db.VarChar(64)
  userId            String   @db.VarChar(64)
  companyId         String?  @db.VarChar(64) // null = admin account, set = employer account
  platform          String   @db.VarChar(30) // FACEBOOK, INSTAGRAM, LINKEDIN, TWITTER, WHATSAPP_CHANNEL
  platformUserId    String?  @db.VarChar(191) // user ID on the platform
  platformUsername  String?  @db.VarChar(191) // username/handle
  accessToken       String?  @db.Text // encrypted access token
  refreshToken      String?  @db.Text // encrypted refresh token
  tokenExpiresAt    DateTime?
  pageId            String?  @db.VarChar(191) // FB Page ID or LinkedIn Org ID
  pageName          String?  @db.VarChar(300) // FB Page name or LinkedIn Org name
  pageAccessToken   String?  @db.Text // Page-specific access token
  isActive          Boolean  @default(true)
  autoPost          Boolean  @default(false) // auto-post when job published
  autoPostJobTypes  String?  @db.Text // JSON array of listingTypes to auto-post (e.g. ["JOB","OPPORTUNITY"])
  lastPostedAt      DateTime?
  metadata          String?  @db.Text // JSON for extra data
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  company    Company?     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  socialPosts SocialPost[]

  @@unique([userId, platform, companyId])
  @@index([platform])
  @@index([companyId])
  @@index([isActive])
}

// ─── Social Posts (tracking social media posts) ───

model SocialPost {
  id              String   @id @default(cuid()) @db.VarChar(64)
  accountId       String   @db.VarChar(64)
  listingId       String?  @db.VarChar(64)
  platform        String   @db.VarChar(30) // FACEBOOK, INSTAGRAM, LINKEDIN, TWITTER, WHATSAPP_CHANNEL
  platformPostId  String?  @db.VarChar(191) // post ID on the platform
  platformUrl     String?  @db.VarChar(500) // URL of the post
  caption         String   @db.Text // post caption/text
  posterUrl       String?  @db.VarChar(500) // path to generated poster image
  status          String   @default("PENDING") @db.VarChar(20) // PENDING, POSTED, FAILED, DELETED
  postType        String   @default("JOB_POSTER") @db.VarChar(30) // JOB_POSTER, ARTICLE, ANNOUNCEMENT
  errorMessage    String?  @db.Text
  metadata        String?  @db.Text // JSON
  postedAt        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  account SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  listing Listing?       @relation(fields: [listingId], references: [id], onDelete: SetNull)

  @@index([accountId])
  @@index([listingId])
  @@index([platform])
  @@index([status])
  @@index([createdAt])
}

// ─── Salary Submissions (salary benchmarking data) ───

model SalarySubmission {
  id              String    @id @default(cuid()) @db.VarChar(64)
  userId          String?   @db.VarChar(64)
  jobTitle        String    @db.VarChar(300)
  company         String?   @db.VarChar(300)
  industry        String?   @db.VarChar(100)
  county          String?   @db.VarChar(100)
  employmentType  String    @default("Full-time") @db.VarChar(20)
  experienceLevel String    @default("Mid-level") @db.VarChar(20)
  salaryAmount    Int
  salaryPeriod    String    @default("MONTHLY") @db.VarChar(20)
  currency        String    @default("KES") @db.VarChar(10)
  benefits        String?   @db.Text // JSON array of benefits
  isVerified      Boolean   @default(false)
  source          String    @default("USER_SUBMISSION") @db.VarChar(30) // USER_SUBMISSION, LISTING_EXTRACTED, ADMIN
  createdAt       DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([jobTitle])
  @@index([industry])
  @@index([county])
  @@index([experienceLevel])
  @@index([employmentType])
  @@index([salaryAmount])
  @@index([createdAt])
}
