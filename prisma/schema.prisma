generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
//  AUTHENTICATION & USERS
// ──────────────────────────────────────────────

model User {
  id            String    @id @default(cuid()) @db.VarChar(30)
  email         String    @unique @db.VarChar(191)
  passwordHash  String    @map("password_hash") @db.VarChar(255)
  name          String?   @db.VarChar(191)
  phone         String?   @map("phone") @db.VarChar(20)
  avatarUrl     String?   @map("avatar_url") @db.VarChar(500)
  role          String    @default("SEEKER") @db.VarChar(20) // SEEKER | EMPLOYER | ADMIN
  isActive      Boolean   @default(true) @map("is_active")

  // Job seeker fields
  county        String?   @db.VarChar(100)
  bio           String?   @db.Text
  resumeUrl     String?   @map("resume_url") @db.VarChar(500)
  linkedInUrl   String?   @map("linkedin_url") @db.VarChar(255)
  skills        String    @default("[]") @db.VarChar(2000) // JSON array of skill strings

  // Employer fields (linked via Company)
  company       Company?  @relation("CompanyOwner")

  // Relationships
  applications  Application[]
  savedJobs     SavedJob[]
  subscriptions NewsletterSubscription[]
  articles      Article[]

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

// ──────────────────────────────────────────────
//  COMPANIES / EMPLOYERS
// ──────────────────────────────────────────────

model Company {
  id            String    @id @default(cuid()) @db.VarChar(30)
  name          String    @db.VarChar(191)
  slug          String    @unique @db.VarChar(191)
  description   String?   @db.Text
  logoUrl       String?   @map("logo_url") @db.VarChar(500)
  website       String?   @db.VarChar(255)
  industry      String?   @db.VarChar(100)
  employeeCount String?   @map("employee_count") @db.VarChar(50)
  hqLocation    String?   @map("hq_location") @db.VarChar(100)
  isVerified    Boolean   @default(false) @map("is_verified")
  isGovernment  Boolean   @default(false) @map("is_government")

  // Ownership
  ownerId       String?   @unique @map("owner_id") @db.VarChar(30)
  owner         User?     @relation("CompanyOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  // Relationships
  jobs          Job[]

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("companies")
}

// ──────────────────────────────────────────────
//  JOB CATEGORIES
// ──────────────────────────────────────────────

model Category {
  id          String  @id @default(cuid()) @db.VarChar(30)
  name        String  @unique @db.VarChar(100)
  slug        String  @unique @db.VarChar(100)
  description String? @db.Text
  icon        String? @db.VarChar(100)
  jobCount    Int     @default(0) @map("job_count")

  // Relationships
  jobs         Job[]
  salaryRecords SalaryRecord[] @relation("CategorySalary")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("categories")
}

// ──────────────────────────────────────────────
//  LOCATIONS
// ──────────────────────────────────────────────

model Location {
  id          String  @id @default(cuid()) @db.VarChar(30)
  name        String  @db.VarChar(100)
  slug        String  @unique @db.VarChar(100)
  type        String  @default("COUNTY") @db.VarChar(20) // COUNTY | AREA | REMOTE
  parentLocationId String? @map("parent_location_id") @db.VarChar(30)
  parentLocation Location? @relation("LocationHierarchy", fields: [parentLocationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  childLocations  Location[] @relation("LocationHierarchy")

  // Relationships
  jobs        Job[]

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("locations")
}

// ──────────────────────────────────────────────
//  JOB LISTINGS
// ──────────────────────────────────────────────

model Job {
  id            String    @id @default(cuid()) @db.VarChar(30)
  slug          String    @unique @db.VarChar(191)

  // Core info
  title         String    @db.VarChar(255)
  description   String    @db.Text
  requirements  String    @db.Text // JSON array

  // Employment details
  type          String    @default("Full-time") @db.VarChar(20)
  level         String    @default("Entry Level") @db.VarChar(30)
  salaryMin     Int?
  salaryMax     Int?
  salaryCurrency String   @default("Ksh") @map("salary_currency") @db.VarChar(10)
  salaryNote    String?   @map("salary_note") @db.VarChar(100)

  // Casual job fields
  casualRate    String?   @map("casual_rate") @db.VarChar(50)
  casualNote    String?   @map("casual_note") @db.VarChar(100)
  isCasual      Boolean   @default(false) @map("is_casual")

  // Government fields
  isGovernment  Boolean   @default(false) @map("is_government")
  isGazette     Boolean   @default(false) @map("is_gazette")
  gazetteRef    String?   @map("gazette_ref") @db.VarChar(100)

  // Status & visibility
  status        String    @default("ACTIVE") @db.VarChar(20)
  isFeatured    Boolean   @default(false) @map("is_featured")
  isUrgent      Boolean   @default(false) @map("is_urgent")
  isRemote      Boolean   @default(false) @map("is_remote")

  // Counts
  viewCount     Int       @default(0) @map("view_count")
  applicationCount Int    @default(0) @map("application_count")

  // Dates
  postedAt      DateTime  @default(now()) @map("posted_at")
  deadlineAt    DateTime? @map("deadline_at")
  featuredAt    DateTime? @map("featured_at")
  closedAt      DateTime? @map("closed_at")

  // Foreign keys
  companyId     String    @db.VarChar(30)
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  categoryId    String    @db.VarChar(30)
  category      Category  @relation(fields: [categoryId], references: [id])
  locationId    String    @db.VarChar(30)
  location      Location  @relation(fields: [locationId], references: [id])

  // Relationships
  applications  Application[]
  savedBy       SavedJob[]
  tags          JobTag[]
  updates       JobUpdate[]

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([companyId])
  @@index([categoryId])
  @@index([locationId])
  @@index([status])
  @@index([isFeatured])
  @@index([isUrgent])
  @@index([deadlineAt])
  @@index([postedAt])

  @@map("jobs")
}

// ──────────────────────────────────────────────
//  JOB TAGS (many-to-many via join table)
// ──────────────────────────────────────────────

model Tag {
  id        String    @id @default(cuid()) @db.VarChar(30)
  name      String    @unique @db.VarChar(100)
  slug      String    @unique @db.VarChar(100)

  // Relationships
  jobs      JobTag[]

  createdAt DateTime  @default(now()) @map("created_at")

  @@map("tags")
}

model JobTag {
  jobId     String    @db.VarChar(30)
  jobIdRef  Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  tagId     String    @db.VarChar(30)
  tagIdRef  Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([jobId, tagId])
  @@map("job_tags")
}

// ──────────────────────────────────────────────
//  JOB APPLICATIONS
// ──────────────────────────────────────────────

model Application {
  id            String    @id @default(cuid()) @db.VarChar(30)

  // Status tracking
  status        String    @default("PENDING") @db.VarChar(20)

  // Applicant info
  coverLetter   String?   @map("cover_letter") @db.Text
  resumeUrl     String?   @map("resume_url") @db.VarChar(500)

  // Employer notes
  employerNotes String?   @map("employer_notes") @db.Text
  rating        Int?

  // Foreign keys
  userId        String    @map("user_id") @db.VarChar(30)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId         String    @map("job_id") @db.VarChar(30)
  job           Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)

  // Dates
  appliedAt     DateTime  @default(now()) @map("applied_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  shortlistedAt DateTime? @map("shortlisted_at")
  interviewAt   DateTime? @map("interview_at")
  respondedAt   DateTime? @map("responded_at")

  @@unique([userId, jobId])
  @@index([jobId, status])
  @@index([userId])

  @@map("applications")
}

// ──────────────────────────────────────────────
//  SAVED / BOOKMARKED JOBS
// ──────────────────────────────────────────────

model SavedJob {
  id        String   @id @default(cuid()) @db.VarChar(30)
  userId    String   @map("user_id") @db.VarChar(30)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId     String   @map("job_id") @db.VarChar(30)
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, jobId])
  @@index([userId])

  @@map("saved_jobs")
}

// ──────────────────────────────────────────────
//  JOB UPDATES (timeline feed items)
// ──────────────────────────────────────────────

model JobUpdate {
  id        String   @id @default(cuid()) @db.VarChar(30)
  content   String   @db.VarChar(500)
  isActive  Boolean  @default(true) @map("is_active")

  // Foreign key
  jobId     String   @map("job_id") @db.VarChar(30)
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([jobId, createdAt])

  @@map("job_updates")
}

// ──────────────────────────────────────────────
//  NEWSLETTER SUBSCRIPTIONS
// ──────────────────────────────────────────────

model NewsletterSubscription {
  id        String   @id @default(cuid()) @db.VarChar(30)
  email     String   @unique @db.VarChar(191)
  isActive  Boolean  @default(true) @map("is_active")

  // Foreign key (optional)
  userId    String?  @unique @map("user_id") @db.VarChar(30)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  subscribedAt DateTime @default(now()) @map("subscribed_at")
  unsubscribedAt DateTime? @map("unsubscribed_at")

  @@index([email])

  @@map("newsletter_subscriptions")
}

// ──────────────────────────────────────────────
//  SALARY RECORDS
// ──────────────────────────────────────────────

model SalaryRecord {
  id          String  @id @default(cuid()) @db.VarChar(30)
  title       String  @db.VarChar(191)
  level       String  @db.VarChar(30)
  location    String  @db.VarChar(100)
  salaryMin   Int
  salaryMax   Int
  currency    String  @default("Ksh") @db.VarChar(10)
  source      String? @db.VarChar(50)
  reportCount Int     @default(1) @map("report_count")

  categoryId  String? @map("category_id") @db.VarChar(30)
  category    Category? @relation("CategorySalary", fields: [categoryId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([title])
  @@index([categoryId])
  @@index([location])

  @@map("salary_records")
}

// ──────────────────────────────────────────────
//  CAREER RESOURCES / ARTICLES
// ──────────────────────────────────────────────

model Article {
  id          String   @id @default(cuid()) @db.VarChar(30)
  title       String   @db.VarChar(255)
  slug        String   @unique @db.VarChar(191)
  excerpt     String?  @db.Text
  content     String?  @db.LongText
  coverUrl    String?  @map("cover_url") @db.VarChar(500)
  category    String?  @db.VarChar(100)
  readTime    String?  @map("read_time") @db.VarChar(20)
  authorId    String?  @map("author_id") @db.VarChar(30)
  author      User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)

  isPublished Boolean  @default(false) @map("is_published")
  viewCount   Int      @default(0) @map("view_count")

  publishedAt DateTime? @map("published_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([isPublished, publishedAt])

  @@map("articles")
}
